# Foundation runtime.
DATABASE_URL=postgresql://agentstudio:agentstudio@localhost:5432/agentstudio
ARTIFACTS_ROOT=artifacts
VOICE_AGENT_PERSIST_AUDIO_ARTIFACTS=true
VOICE_AGENT_AUDIO_ARTIFACT_MAX_BYTES=960000
VOICE_AGENT_AUDIO_ARTIFACT_RETENTION_DAYS=7
VOICE_AGENT_AUDIO_ARTIFACT_CLEANUP_INTERVAL_SECONDS=3600
PLANNING_ARTIFACT_PATH=planning/foundation-system-design.html
# Production mutating API requests require this bearer token. Prefer the
# ignored file path and leave the direct value blank in committed examples.
ADMIN_API_TOKEN=
ADMIN_API_TOKEN_FILE=.secrets/admin_api_token

# Legacy expert-agent endpoints. Leave disabled unless explicitly running a
# historical/native-model experiment. Do not use these for the current
# OpenRouter/LiveKit realtime dialogue path.
HF_TOKEN=
# Preferred local path: put the token in this ignored file instead of storing
# HF_TOKEN directly in .env. Direct HF_TOKEN still overrides the file.
HF_TOKEN_FILE=.secrets/hf_token
HF_INFERENCE_ROUTER_ENABLED=false
HF_INFERENCE_ROUTER_CHAT_COMPLETIONS_URL=https://router.huggingface.co/v1/chat/completions
GEMMA4_PRIMARY_MODEL_ID=google/gemma-4-31b-it
GEMMA4_PRIMARY_ENDPOINT_URL=
GEMMA4_FAST_MODEL_ID=google/gemma-4-26b-a4b-it
GEMMA4_FAST_ENDPOINT_URL=
GEMMA4_MULTIMODAL_MODEL_ID=google/gemma-4-e4b-it
GEMMA4_MULTIMODAL_ENDPOINT_URL=
LOCAL_PROVIDER_CONFIG_FILE=.secrets/local_provider_config.json

# Provider-pluggable realtime speech-to-speech layer.
# Default path: OpenRouter DeepSeek V4 Flash + LiveKit + Kokoro-82M.
# Some compatibility variable names still start with GEMMA4_REALTIME_; in this
# route they configure the OpenRouter/LiveKit/Kokoro path, not Hugging Face.
REALTIME_DEFAULT_PROVIDER=openrouter_livekit
OPENROUTER_LIVEKIT_URL=ws://127.0.0.1:7880
GEMMA4_REALTIME_TRANSPORT_FRAMEWORK=livekit
GEMMA4_REALTIME_LIVEKIT_URL=
# Local LiveKit dev mode (`livekit-server --dev`, supervised `docker compose --profile voice up livekit`, or manual detached Compose)
# needs local-only API credentials. Store real values in ignored env/secret
# files; this example intentionally carries no credential values.
LIVEKIT_API_KEY=
# Preferred local paths: put LiveKit credentials in ignored files instead of
# storing LIVEKIT_API_KEY / LIVEKIT_API_SECRET directly in .env. Direct env
# values still override the files.
LIVEKIT_API_KEY_FILE=.secrets/livekit_api_key
LIVEKIT_API_SECRET=
LIVEKIT_API_SECRET_FILE=.secrets/livekit_api_secret
LIVEKIT_CONNECTIVITY_PREFLIGHT_TIMEOUT_SECONDS=3
GEMMA4_REALTIME_LIVEKIT_TOKEN_TTL_SECONDS=3600
GEMMA4_REALTIME_WS_URL=
GEMMA4_REALTIME_AUDIO_INPUT_MODEL=deepseek/deepseek-v4-flash
GEMMA4_REALTIME_REASONING_MODEL=deepseek/deepseek-v4-flash
GEMMA4_REALTIME_AUDIO_OUTPUT_MODEL=hexgrad/Kokoro-82M
GEMMA4_REALTIME_AUDIO_FORMAT=pcm_s16le
GEMMA4_REALTIME_SAMPLE_RATE=16000
GEMMA4_REALTIME_CONTEXT_WINDOW_TURNS=4
GEMMA4_REALTIME_CONTEXT_PRUNE_AFTER_TURNS=3
GEMMA4_REALTIME_MAX_AUDIO_SECONDS_PER_TURN=30
GEMMA4_REALTIME_TTS_FLUSH_CHARS=180
GEMMA4_REALTIME_DEFAULT_VOICE=af_heart
GEMMA4_REALTIME_RUST_VAD_MODEL=silero-vad-rust
RUST_VOICE_EDGE_BINARY_PATH=services/voice-edge/target/debug/voice-edge
RUST_VOICE_EDGE_TIMEOUT_SECONDS=1
RUST_VOICE_EDGE_VAD_BACKEND=deterministic_energy
RUST_VOICE_EDGE_VAD_MODEL_PATH=
RUST_VOICE_EDGE_ALLOW_VAD_FALLBACK=true
RUST_VOICE_EDGE_VAD_THRESHOLD=0.018
RUST_VOICE_EDGE_VAD_PROBABILITY_THRESHOLD=0.5
RUST_VOICE_EDGE_VAD_SESSION_POOL_SIZE=4
RUST_VOICE_EDGE_VAD_STREAM_STATE_CACHE_SIZE=512
RUST_VOICE_EDGE_BENCHMARK_SPEECH_WAV_PATH=
RUST_VOICE_EDGE_BENCHMARK_MAX_SPEECH_FRAMES=64
RUST_VOICE_EDGE_MIN_SPEECH_FRAMES=2
RUST_VOICE_EDGE_MIN_SILENCE_FRAMES=16
RUST_VOICE_EDGE_TURN_PRE_ROLL_FRAMES=3
RUST_VOICE_EDGE_FRAME_MS=32
RUST_VOICE_EDGE_MAX_INBOUND_BUFFER_BYTES=960000
RUST_VOICE_EDGE_MAX_OUTBOUND_BUFFER_BYTES=64000
LIVEKIT_AGENT_NAME=openrouter-kokoro-agent
LIVEKIT_AGENT_LOG_LEVEL=INFO
VOICE_AGENT_SUPERVISOR_ENABLED=true
VOICE_AGENT_SUPERVISOR_LOG_LINES=80
VOICE_AGENT_BACKEND_EVENT_SINK_ENABLED=true
VOICE_AGENT_BACKEND_EVENT_SINK_URL=http://127.0.0.1:8000
VOICE_AGENT_BACKEND_EVENT_SINK_TIMEOUT_SECONDS=2
LOCAL_LIVEKIT_SUPERVISOR_ENABLED=true
LOCAL_LIVEKIT_SUPERVISOR_LOG_LINES=80
KOKORO_TTS_ENDPOINT_URL=
KOKORO_TTS_CHUNK_BYTES=6400
KOKORO_TTS_TIMEOUT_SECONDS=60

# OpenRouter live dialogue reasoning for the default realtime path.
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_FILE=.secrets/openrouter_api_key
OPENROUTER_CHAT_COMPLETIONS_URL=https://openrouter.ai/api/v1/chat/completions

# Generic open-source runtime fallback. Leave disabled for the default
# OpenRouter/LiveKit/Kokoro route.
OPEN_SOURCE_REALTIME_WS_URL=
OPEN_SOURCE_REALTIME_STT_MODEL=nvidia/parakeet-tdt-0.6b-v2
OPEN_SOURCE_REALTIME_LLM_MODEL=
OPEN_SOURCE_REALTIME_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
OPEN_SOURCE_REALTIME_AUDIO_FORMAT=pcm_s16le
OPEN_SOURCE_REALTIME_SAMPLE_RATE=16000

# Optional proprietary adapters. Do not enable for the default product path.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_v3

CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CARTESIA_MODEL_ID=sonic-3.5

# Source-backed content generation.
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
# Preferred local path: put the key in this ignored file instead of storing
# TAVILY_API_KEY directly in .env. Direct TAVILY_API_KEY still overrides the file.
TAVILY_API_KEY_FILE=.secrets/tavily_api_key
SERPAPI_API_KEY=

# Optional social publishing credentials for non-live publish-channel readiness checks.
# These checks only verify local credential presence; they do not publish externally.
# Preferred local path: put tokens in these ignored files instead of storing
# direct token values in .env. Direct token env vars still override files.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN_FILE=.secrets/instagram_access_token
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN_FILE=.secrets/linkedin_access_token
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_FILE=.secrets/x_access_token
X_API_KEY=
X_API_KEY_FILE=.secrets/x_api_key
SUBSTACK_API_TOKEN=
SUBSTACK_API_TOKEN_FILE=.secrets/substack_api_token

RERANKER_PROVIDER=deterministic
RUST_RERANKER_BINARY_PATH=services/retrieval-ranker/target/debug/retrieval-ranker
RUST_RERANKER_TIMEOUT_SECONDS=2.0
