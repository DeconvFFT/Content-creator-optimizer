# No-secret example for the ignored Agent Studio external publication operator input file.
# Copy these keys into:
# social_media_optimiser/output/provider-proof/190ae2f9-a74b-4a23-b39c-aaf2d636bd8e/operator-inputs.template.env
#
# Replace placeholder paths and URLs locally. Do not paste token values here or commit
# any filled operator input file.

LINKEDIN_ACCESS_TOKEN_FILE=/absolute/path/to/local/linkedin-access-token.txt
LINKEDIN_POLICY_ACKNOWLEDGEMENT_ARTIFACT_ID=https://docs.example.com/linkedin-policy-acknowledgement
PUBLICATION_DURABLE_PLATFORM_ID_OR_URL=<durable-linkedin-publication-url-or-id>
PUBLICATION_ROLLBACK_OR_POSTCONDITION_ARTIFACT_ID=https://docs.example.com/publication-rollback-or-postcondition
